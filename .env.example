# Aptiro configuration. Every setting is APTIRO_-prefixed so it never
# collides with generic vars other apps export. Copy to .env and edit.

# --- Database ---------------------------------------------------------
# Zero-config default is bundled SQLite. The PRODUCTION path is Postgres
# + pgvector (docker-compose provides it). Tests always use in-memory
# SQLite regardless of this value.
# APTIRO_DATABASE_URL=sqlite:///./aptiro.db
APTIRO_DATABASE_URL=postgresql+psycopg2://aptiro:aptiro@db:5432/aptiro

# --- AI provider (Decision 2: deterministic mock is the DEFAULT) ------
# The app and the test suite run with zero credentials. Anthropic is
# used ONLY when both of the next two are set AND the SDK is installed;
# otherwise it transparently falls back to the mock.
APTIRO_AI_PROVIDER=mock
# APTIRO_AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# APTIRO_ANTHROPIC_MODEL=claude-sonnet-4-5
# Phase 5 cost/latency ceilings for the optional real path (the mock
# ignores them). Every AI output is provenance-gated regardless.
APTIRO_AI_MAX_TOKENS=700
APTIRO_AI_TIMEOUT=20

# --- Embedding provider (Phase 2: SECONDARY semantic signal only) -----
# Deterministic mock is the DEFAULT. The semantic similarity it produces
# is a labelled secondary indicator and NEVER affects the 0-100 score or
# the match ranking. A real model is opt-in and falls back to mock.
APTIRO_EMBEDDING_PROVIDER=mock
# APTIRO_EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# APTIRO_EMBEDDING_MODEL=text-embedding-3-small

# --- URL job import guardrails (Phase 2) ------------------------------
# Server-side fetch of ONE user-supplied public URL (never a crawler).
APTIRO_URL_FETCH_TIMEOUT=10
APTIRO_URL_FETCH_MAX_BYTES=2097152

# --- Other providers (all mocked in this slice) -----------------------
APTIRO_JOB_PROVIDER=mock
APTIRO_SEARCH_PROVIDER=mock
APTIRO_NOTIFICATION_PROVIDER=mock

# --- Ingestion --------------------------------------------------------
APTIRO_MAX_UPLOAD_MB=10

# --- Lifecycle --------------------------------------------------------
APTIRO_SEED_ON_STARTUP=1

# --- Phase 4: multi-user & auth ---------------------------------------
# OFF by default: every request is the built-in 'local' user and the
# app behaves exactly as single-user. Set to on/1/true to require a
# bearer token for mutating requests and isolate data per account.
APTIRO_AUTH=off

# --- Phase 6: observability -------------------------------------------
# Structured JSON logs + per-request IDs + append-only audit are always
# on. This only tunes log verbosity.
APTIRO_LOG_LEVEL=INFO

# --- Phase 7: notifications -------------------------------------------
# SMTP (all optional; nothing is sent until APTIRO_SMTP_HOST is set)
# APTIRO_SMTP_HOST=smtp.example.com
# APTIRO_SMTP_PORT=587
# APTIRO_SMTP_USER=user@example.com
# APTIRO_SMTP_PASS=secret
# APTIRO_SMTP_FROM=aptiro@example.com
# APTIRO_SMTP_TLS=starttls   # starttls | ssl | none

# Twilio SMS (opt-in; user must also enable SMS in notification prefs)
# APTIRO_TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# APTIRO_TWILIO_TOKEN=your_auth_token
# APTIRO_TWILIO_FROM=+15551234567

# --- Phase 8: auth hardening & launch security ------------------------
# Deployment environment. Set to "production" to:
#   • Enable HSTS (Strict-Transport-Security) headers
#   • Enable rate limiting by default
#   • Log a warning if APTIRO_AUTH is not set
# Default: development (no HSTS, rate limiting off unless explicit)
APTIRO_ENV=development

# Session token lifetime in hours. 0 = tokens never expire (default).
# Recommended values: 72 for personal/dev, 8 for shared production.
# When > 0, use POST /api/auth/rotate to get a token with the expiry stamped.
APTIRO_SESSION_HOURS=0

# Rate limits (requests per minute per source IP).
# Only active when APTIRO_ENV=production OR these vars are explicitly set.
# Defaults are intentionally permissive so local/dev use is unaffected.
APTIRO_AUTH_RATE_LIMIT=100
APTIRO_MUTATE_RATE_LIMIT=300

# Secret for HMAC signing of export download links.
# Auto-generated at startup if not set (links won't survive restarts).
# MUST be set in production to a long random value.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
APTIRO_EXPORT_SECRET=change-me-in-production

# --- Dev server ports (used by RUN.sh) --------------------------------
APTIRO_API_PORT=8000
APTIRO_UI_PORT=5173
