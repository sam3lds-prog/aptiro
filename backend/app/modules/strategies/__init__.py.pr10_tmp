"""Aptiro backend module: `app.modules.strategies`.

Phase 9 PR-10 — multi-strategy domain extracted from legacy.py:
  * Constant  — STRATEGY_PRESETS (six tuned presets)
  * Model     — Strategy
  * Schemas   — StrategyUpsert, StrategyRead, StrategyCreate,
                StrategyListItem, StrategyPreviewCounts,
                StrategyPreviewOut, SeedPresetsOut,
                StrategyDraftPreviewIn
  * Helpers   — _list_strategies, _get_owned_strategy,
                _strategy_list_item, _ensure_one_active,
                _apply_body_to_strategy, _preview_counts,
                _preview_summary
  * Router    — strategies_router with 9 endpoints

Behavior is identical to pre-PR-10. legacy.py re-imports every moved
name so the test contract (`import app as A; A.Strategy`,
`A.STRATEGY_PRESETS`, `A.strategies_router`, `A._preview_counts`,
`A.StrategyUpsert`, etc.) is unchanged.

Cross-module dependencies
─────────────────────────
  At module load:
    app.core.config            DEFAULT_UID
    app.core.identity          _uid
    app.db.engine              _now, get_session
    app.modules.jobs           WorkMode, JobPosting (PR-9)
    app.legacy                 Aggressiveness, DEFAULT_WEIGHTS
                               (defined EARLY in legacy, before PR-10)
  At runtime (lazy wrappers — still in legacy):
    app.legacy                 score_job, _active_strategy,
                               _strategy_read

# APTIRO_PHASE9_PR10_STRATEGIES_MARKER
"""

import uuid as _uuidmod
from datetime import datetime
from typing import List, Optional

from fastapi import APIRouter, Depends, HTTPException, Response
from pydantic import BaseModel
from sqlalchemy import Column, JSON
from sqlmodel import Field, Session, SQLModel, select

from app.core.config import DEFAULT_UID
from app.core.identity import _uid
from app.db.engine import _now, get_session

# WorkMode + JobPosting were extracted to modules.jobs in PR-9.
# Direct import is safe: jobs module loaded BEFORE strategies module.
from app.modules.jobs import JobPosting, WorkMode  # noqa: F401

# Aggressiveness + DEFAULT_WEIGHTS still live in legacy. Both are
# defined EARLY in legacy (enums + constants section), BEFORE the
# legacy line that imports from app.modules.strategies, so they're
# in legacy's namespace by the time this module loads.
from app.legacy import Aggressiveness, DEFAULT_WEIGHTS  # noqa: F401


def _uuid() -> str:
    return _uuidmod.uuid4().hex


# ---------------------------------------------------------------------------
# Lazy bridges to legacy (still home for these helpers until PR-11+).
# Each wrapper shares the legacy name exactly so extracted endpoint /
# helper bodies use them unchanged. Imports inside the function body —
# not at module load — to avoid a circular import during legacy.py's
# own bootstrapping.
# ---------------------------------------------------------------------------

def score_job(*args, **kwargs):
    """Lazy bridge to legacy.score_job (moves at PR-11)."""
    from app.legacy import score_job as _impl  # noqa: PLC0415
    return _impl(*args, **kwargs)


def _active_strategy(*args, **kwargs):
    """Lazy bridge to legacy._active_strategy."""
    from app.legacy import _active_strategy as _impl  # noqa: PLC0415
    return _impl(*args, **kwargs)


def _strategy_read(*args, **kwargs):
    """Lazy bridge to legacy._strategy_read."""
    from app.legacy import _strategy_read as _impl  # noqa: PLC0415
    return _impl(*args, **kwargs)


# ---------------------------------------------------------------------------
# === Extracted blocks (preserved verbatim from legacy.py) ===
# ---------------------------------------------------------------------------

